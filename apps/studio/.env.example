STUDIO_PG_META_URL=http://localhost:8000/pg
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Must match CRYPTO_KEY in the pg-meta container (used to encrypt x-connection-encrypted headers)
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

# Docker bridge gateway IP — how the pg-meta container reaches host-mapped ports for other stacks.
# Run: docker network inspect supabase_default | grep Gateway
# Use "host.docker.internal" on Docker Desktop (Mac/Windows); bridge IP on Linux Docker.
MULTI_HEAD_HOST=localhost

# Path to the Supabase docker-compose.yml used as a template for new project stacks
SUPABASE_COMPOSE_FILE=/home/ubuntu/supabase/supabase-multi-head/docker/docker-compose.yml

DEFAULT_ORGANIZATION_NAME=Default Organization
DEFAULT_PROJECT_NAME=Default Project
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

SUPABASE_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
SENTRY_IGNORE_API_RESOLUTION_ERROR=1
LOGFLARE_URL=http://localhost:4000
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# TODO: evaluate these variables at runtime instead
# https://nextjs.org/docs/basic-features/environment-variables#loading-environment-variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOTRUE_URL=$SUPABASE_PUBLIC_URL/auth/v1

# --- GoTrue-backed Studio auth (recommended) ---
# Set NEXT_PUBLIC_STUDIO_AUTH=gotrue to use the Docker stack's GoTrue as the Studio
# login provider instead of the simple HMAC session cookie.
# Then visit http://localhost:3000/setup on first run to create the initial admin.
#
# NEXT_PUBLIC_STUDIO_AUTH=gotrue
#
# Service role key for the default project — allows Studio to call the GoTrue admin API
# (create/delete Studio users).  Paste the SERVICE_ROLE_KEY from your docker/.env here.
# STUDIO_GOTRUE_SERVICE_KEY=<your-service-role-jwt>

# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=  # Only needed for platform deployments

# CmdK / AI — optional, only needed if you want the AI assistant
# Create a project at supabase.com and paste its anon key + URL here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Required to manage edge-functions via dashboard on Self-Hosting
# EDGE_FUNCTIONS_MANAGEMENT_FOLDER=/path-where-edge-functions-are-mounted
